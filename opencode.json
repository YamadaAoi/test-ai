{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/**/*.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "mock/**"
    ]
  },
  "permission": {
    "webfetch": "allow"
  },
  "mcp": {
    "mcp-sketch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-sketch"
      ],
      "enabled": true,
      "environment": {
        "LOG_LEVEL": "debug"
      }
    }
  }
}